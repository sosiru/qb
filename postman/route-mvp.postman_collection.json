    {
      "name": "List Batches",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/batches/?organization_id={{organization_id}}"
      }
    },
    {
      "name": "Get Batch Detail",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/batches/{{batch_id}}/"
