        "body": {
          "mode": "raw",
          "raw": "{\n  \"label\": \"KPLC\",\n  \"payee_type\": \"PAYBILL\",\n  \"paybill_number\": \"888880\",\n  \"account_reference\": \"ACC123\",\n  \"expense_category\": \"utilities\"\n}"
