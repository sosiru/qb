        },
        "url": "{{base_url}}/schedules/"
      }
    },
    {
      "name": "Update Schedule",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"day_of_month\": 10,\n  \"active\": false\n}"
        },
        "url": "{{base_url}}/schedules/{{schedule_id}}/"
