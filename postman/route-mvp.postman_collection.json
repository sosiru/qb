    {
      "name": "Submit Corporate Batch",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{}" },
        "url": "{{base_url}}/corporate/batches/{{batch_id}}/submit/"
      }
    },
    {
      "name": "Approve Corporate Batch",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{checker_token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{}" },
        "url": "{{base_url}}/corporate/batches/{{batch_id}}/approve/"
      }
    },
    {
      "name": "Reject Corporate Batch",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{checker_token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Incorrect beneficiary amount\"\n}"
        },
        "url": "{{base_url}}/corporate/batches/{{batch_id}}/reject/"
      }
