    {
      "name": "Pay All Via STK",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"payment_mode\": \"STK\",\n  \"simulate_collection\": false\n}"
        },
        "url": "{{base_url}}/payments/pay-all/"
      }
    },
    {
      "name": "Top Up Corporate Wallet",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
