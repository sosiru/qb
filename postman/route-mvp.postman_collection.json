{
  "info": {
    "name": "Route MVP",
    "_postman_id": "9a7f4f8a-53a1-4dbc-b28b-7f4f95cd1234",
    "description": "Postman collection for the Route (Bundl Pay) MVP backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8006/api/v1" },
    { "key": "token", "value": "" },
    { "key": "checker_token", "value": "" },
    { "key": "organization_id", "value": "" },
    { "key": "checker_user_id", "value": "" },
    { "key": "payee_id", "value": "" },
    { "key": "schedule_id", "value": "" },
    { "key": "membership_id", "value": "" },
    { "key": "batch_id", "value": "" },
    { "key": "integration_api_key_id", "value": "" },
    { "key": "integration_secret", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health/"
      }
    },
    {
      "name": "Register Individual",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone_number\": \"+254700000001\",\n  \"password\": \"StrongPass123!\",\n  \"full_name\": \"Alice Example\",\n  \"account_type\": \"INDIVIDUAL\",\n  \"default_payment_mode\": \"WALLET\"\n}"
        },
        "url": "{{base_url}}/auth/register/"
      }
    },
    {
      "name": "Register Corporate Admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone_number\": \"+254700000010\",\n  \"password\": \"StrongPass123!\",\n  \"full_name\": \"Finance Admin\",\n  \"account_type\": \"CORPORATE\",\n  \"organization_name\": \"Bundl Labs\"\n}"
        },
        "url": "{{base_url}}/auth/register/"
      }
    },
    {
      "name": "Register Corporate Checker",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone_number\": \"+254700000011\",\n  \"password\": \"StrongPass123!\",\n  \"full_name\": \"Checker User\",\n  \"account_type\": \"CORPORATE\"\n}"
        },
        "url": "{{base_url}}/auth/register/"
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone_number\": \"+254700000001\",\n  \"password\": \"StrongPass123!\"\n}"
        },
        "url": "{{base_url}}/auth/login/"
      }
    },
    {
      "name": "Get Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/auth/me/"
      }
    },
    {
      "name": "Update My Profile",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"full_name\": \"Alice Example Updated\",\n  \"default_payment_mode\": \"STK\",\n  \"sms_notifications_enabled\": true,\n  \"email_notifications_enabled\": true\n}"
        },
        "url": "{{base_url}}/auth/me/"
      }
    },
    {
      "name": "Get Me Via API Key",
      "request": {
        "method": "GET",
        "header": [{ "key": "X-API-Key", "value": "{{integration_secret}}" }],
        "url": "{{base_url}}/auth/me/"
      }
    },
    {
      "name": "Create Integration API Key",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"ERP Sync\",\n  \"scopes\": [\"read\", \"write\"]\n}"
        },
        "url": "{{base_url}}/integrations/api-keys/"
      }
    },
    {
      "name": "List Integration API Keys",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/integrations/api-keys/"
      }
    },
    {
      "name": "Revoke Integration API Key",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{}" },
        "url": "{{base_url}}/integrations/api-keys/{{integration_api_key_id}}/revoke/"
      }
    },
    {
      "name": "Get Dashboard",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/dashboard/"
      }
    },
    {
      "name": "List Organizations",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/organizations/"
      }
    },
    {
      "name": "Add Checker To Organization",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{checker_user_id}}\",\n  \"role\": \"CHECKER\"\n}"
